{
  "name": "Polystrukt GenCAD Test Suite",
  "baseUrl": "http://localhost:3000",
  "scenarios": [
    {
      "name": "Full Synthesis Flow",
      "steps": [
        { "action": "navigate", "url": "/" },
        { "action": "click", "selector": "[data-testid='nav-start-generating']" },
        { "action": "type", "selector": "[data-testid='workspace-prompt-input']", "text": "DIAGNOSTIC_RUN" },
        { "action": "click", "selector": "[data-testid='workspace-generate-btn']" },
        { "action": "waitFor", "selector": "[data-testid='inspectable-model-canvas']" },
        { "action": "assertVisible", "selector": "[data-testid='workspace-design-panel']" }
      ]
    },
    {
      "name": "Interactive Measurement",
      "steps": [
        { "action": "click", "selector": "[data-testid='toggle-measure-btn']" },
        { "action": "assertVisible", "selector": "[data-testid='measure-active-panel']" },
        { "action": "click", "selector": "[data-testid='measure-close-btn']" }
      ]
    },
    {
      "name": "Chat Assistant Verification",
      "steps": [
        { "action": "click", "selector": "[data-testid='chat-trigger']" },
        { "action": "click", "selector": "[data-testid='suggestion-btn-0']" },
        { "action": "waitFor", "selector": "[data-testid='bot-typing-indicator']", "state": "hidden" },
        { "action": "assertVisible", "selector": "[data-testid='chat-message-model']" }
      ]
    }
  ],
  "selectors": {
    "canvas": "[data-testid='inspectable-model-canvas']",
    "promptInput": "[data-testid='workspace-prompt-input']",
    "errorPanel": "[data-testid='workspace-error-panel']"
  }
}